rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Match any document in the 'users' collection
    match /users/{userId} {
      // Allow users to read their own data
      allow read: if request.auth != null && request.auth.uid == userId;
      
      // Allow creation during signup, but ONLY if the initial plan is 'free'
      allow create: if request.auth != null && request.auth.uid == userId
                    && request.resource.data.plan == 'free';
      
      // Allow users to update their own metadata (email, lastLogin)
      // but strictly block client-side updates to 'plan' or 'subscription' status
      allow update: if request.auth != null && request.auth.uid == userId
                    && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['plan', 'subscription']));
    }
  }
}
